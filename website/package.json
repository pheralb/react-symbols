{
  "name": "@react-symbols/website",
  "version": "4.4.0",
  "description": "React Symbols Icons Website - Built with React Router 7.",
  "author": "@pheralb_",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm build:registry && react-router build",
    "build:registry": "tsx ./app/generators/generate-shadcn-registry.ts",
    "build:shadcn": "shadcn build",
    "build:extensions": "tsx ./app/generators/generate-icons-extensions.ts",
    "dev": "react-router dev",
    "lint": "react-router typegen && eslint ./app",
    "lint:fix": "react-router typegen && eslint ./app --fix",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc --noEmit"
  },
  "dependencies": {
    "@pheralb/toast": "1.0.0",
    "@react-router/fs-routes": "7.14.2",
    "@react-router/node": "7.14.2",
    "@react-router/serve": "7.14.2",
    "@react-symbols/icons": "workspace:*",
    "@vercel/react-router": "1.2.6",
    "axios": "1.15.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "fast-npm-meta": "1.5.0",
    "isbot": "5.1.39",
    "lucide-react": "1.14.0",
    "radix-ui": "1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router": "7.14.2",
    "remix-themes": "2.0.4",
    "shadcn": "4.6.0",
    "sugar-high": "1.1.0",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.5",
    "@eslint/js": "10.0.1",
    "@react-router/dev": "7.14.2",
    "@tailwindcss/vite": "4.2.4",
    "@types/node": "22.19.17",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.0",
    "eslint": "10.2.1",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.5.0",
    "tailwindcss": "4.2.4",
    "tsx": "4.21.0",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.1",
    "vite": "8.0.10",
    "vite-plugin-devtools-json": "1.0.0"
  }
}
